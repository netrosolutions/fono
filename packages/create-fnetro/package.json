{
  "name": "create-fnetro",
  "version": "0.2.0",
  "description": "Create a new FNetro (SolidJS + Hono) project",
  "type": "module",
  "license": "MIT",
  "author": "Netro Solutions<info@netrosolutions.com>",
  "homepage": "https://github.com/netrosolutions/fnetro",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/netrosolutions/fnetro.git",
    "directory": "packages/create-fnetro"
  },
  "bugs": {
    "url": "https://github.com/netrosolutions/fnetro/issues"
  },
  "keywords": ["create-fnetro", "fnetro", "hono", "solidjs", "scaffold", "cli"],
  "bin": {
    "create-fnetro": "./dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build":          "tsup src/index.ts --format esm --dts --outDir dist --target node18 --banner.js '#!/usr/bin/env node'",
    "build:watch":    "tsup src/index.ts --format esm --outDir dist --watch",
    "typecheck":      "tsc --noEmit",
    "clean":          "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "dependencies": {
    "kolorist": "^1.8.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  }
}
