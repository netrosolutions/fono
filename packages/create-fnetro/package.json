{
  "name": "@netrojs/create-fnetro",
  "version": "0.1.4",
  "description": "Create a new FNetro app — SSR + SPA full-stack Hono framework",
  "type": "module",
  "license": "MIT",
  "bin": {
    "create-fnetro": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node18 --dts --clean",
    "dev": "tsup src/index.ts --format esm --target node18 --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "kolorist": "^1.8.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["create-fnetro", "fnetro", "hono", "fullstack", "ssr", "spa"]
}