{
  "name": "@netrojs/fnetro",
  "version": "0.1.4",
  "description": "Full-stack Hono framework — SSR, SPA, Vue-like reactivity, route groups, middleware and API routes",
  "type": "module",
  "license": "MIT",
  "author": "MD Ashikur Rahman<info@netrosolutions.com>",
  "homepage": "https://github.com/netrosolutions/fnetro",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/netrosolutions/fnetro.git",
    "directory": "packages/fnetro"
  },
  "bugs": {
    "url": "https://github.com/netrosolutions/fnetro/issues"
  },
  "keywords": [
    "fnetro",
    "hono",
    "framework",
    "fullstack",
    "ssr",
    "spa",
    "reactivity",
    "signals",
    "jsx",
    "tsx",
    "node",
    "bun",
    "deno",
    "cloudflare-workers",
    "edge"
  ],
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./vite": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "main": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "files": [
    "dist",
    "core.ts",
    "server.ts",
    "client.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "peerDependencies": {
    "hono": ">=4.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "@types/node": "^25.5.0",
    "hono": "^4.12.8",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  }
}
