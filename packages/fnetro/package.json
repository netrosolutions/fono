{
  "name": "@netrojs/vono",
  "version": "0.1.1",
  "description": "Full-stack Hono + Vue 3 framework \u2014 Streaming SSR, SPA, code splitting, SEO, middleware",
  "type": "module",
  "license": "MIT",
  "author": "Netro Solutions<info@netrosolutions.com>",
  "homepage": "https://github.com/netrosolutions/vono",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/netrosolutions/vono.git",
    "directory": "packages/vono"
  },
  "bugs": {
    "url": "https://github.com/netrosolutions/vono/issues"
  },
  "keywords": [
    "vono",
    "hono",
    "vue",
    "vue3",
    "fullstack",
    "ssr",
    "streaming",
    "spa",
    "seo",
    "typescript",
    "node",
    "bun",
    "deno",
    "edge"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./vite": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "main": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "files": [
    "dist",
    "types.ts",
    "core.ts",
    "server.ts",
    "client.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "peerDependencies": {
    "vue": ">=3.5.0",
    "vue-router": ">=4.4.0",
    "@vue/server-renderer": ">=3.5.0",
    "hono": ">=4.0.0",
    "vite": ">=6.0.0",
    "@vitejs/plugin-vue": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "@vitejs/plugin-vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/server-renderer": "^3.5.30",
    "hono": "^4.12.8",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  } 
}