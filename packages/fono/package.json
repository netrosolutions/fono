{
  "name": "fono",
  "version": "0.1.0",
  "description": "Full-stack Hono framework — SSR, SPA, Vue-like reactivity, route groups, middleware and API routes in 3 files",
  "type": "module",
  "license": "MIT",
  "author": "Your Name <you@example.com>",
  "homepage": "https://github.com/your-org/fono#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/fono.git",
    "directory": "packages/fono"
  },
  "bugs": {
    "url": "https://github.com/your-org/fono/issues"
  },
  "keywords": [
    "hono", "framework", "fullstack", "ssr", "spa", "reactivity",
    "signals", "jsx", "tsx", "node", "bun", "deno", "cloudflare-workers", "edge"
  ],
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./vite": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "main": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "files": [
    "dist",
    "core.ts",
    "server.ts",
    "client.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "peerDependencies": {
    "hono": ">=4.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.14.0",
    "@types/node": "^22.0.0",
    "hono": "^4.12.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
